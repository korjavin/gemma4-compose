# vLLM API Configuration
VLLM_API_PORT=8000
VLLM_NCCL_TIMEOUT_S=600

# Model Configuration
VLLM_MODEL=google/gemma-4-9b
VLLM_DTYPE=auto
VLLM_QUANTIZATION=gptq
VRAM_FRACTION=0.9

# GPU Configuration
CUDA_VISIBLE_DEVICES=0

# Cache Configuration
HF_CACHE_DIR=$HOME/.cache/huggingface/hub

# Traefik Configuration
TRAEFIK_HOST=gemma4.local
TRAEFIK_ENTRYPOINT=websecure

# Container Configuration
CONTAINER_NAME=gemma4-api
LOG_LEVEL=info
