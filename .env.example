# vLLM API Configuration
VLLM_API_PORT=8000
NCCL_TIMEOUT_S=600

# Model Configuration
VLLM_MODEL=google/gemma-4-9b
VLLM_DTYPE=auto
VLLM_QUANTIZATION=gptq
VRAM_FRACTION=0.9

# GPU Configuration
CUDA_VISIBLE_DEVICES=0

# Cache Configuration
# Optionally set to absolute path on host for persistent model cache across containers
# If unset, uses named docker volume 'gemma4_hf_cache'
# Example: HF_CACHE_DIR=/home/user/.cache/huggingface/hub
# HF_CACHE_DIR=

# Traefik Configuration
TRAEFIK_HOST=gemma4.local
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# Container Configuration
CONTAINER_NAME=gemma4-api
LOG_LEVEL=info
