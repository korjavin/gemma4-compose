# Authentication
# Bearer token for API access. Use a strong random value.
# Generate one: openssl rand -hex 32
# Clients authenticate via: Authorization: Bearer <API_KEY>
API_KEY=sk-change-me-to-a-random-secret

# Model Configuration
# Model name in Ollama format (e.g., gemma:7b, llama2:70b, etc.)
OLLAMA_MODEL=gemma:7b
# How long to keep model in memory after last request (5m, 1h, etc.)
OLLAMA_KEEP_ALIVE=5m

# Cache Configuration
# Path where Ollama model cache is stored. Defaults to Docker's internal
# volume location. For production on hosts with limited root disk space, set to
# an external mount point with sufficient space (e.g. /mnt/HC_Volume_105196246/ollama_cache).
# The directory must exist and be writable by the container.
MODEL_CACHE_PATH=/mnt/HC_Volume_105196246/ollama_cache

# Traefik & Network Configuration
# Name of the external network to connect to (typically 'docker' or 'traefik_default')
NETWORK_NAME=docker
TRAEFIK_HOST=gemma4.local
TRAEFIK_ENTRYPOINT=websecure
# Traefik ACME/Let's Encrypt cert resolver name (matches your Traefik config)
TRAEFIK_CERTRESOLVER=myresolver
# TLS is enabled on the router (tls=true). Certificate source is configured at
# the Traefik level:
#   - Automatic (ACME/Let's Encrypt, Tailscale): configure a certificatesResolver
#     in Traefik and add a label override, e.g. via a compose override file:
#       traefik.http.routers.gemma4.tls.certresolver: letsencrypt
#   - Manual certificates: configure them via Traefik's file provider using
#     the tls.certificates list — no per-router label is required.

# Container Configuration
CONTAINER_NAME=gemma4-api
