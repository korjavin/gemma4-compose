# vLLM API Configuration
VLLM_API_PORT=8000
# Host interface to bind the published port to. Defaults to 127.0.0.1 so the
# raw API is not reachable outside the host; production relies on Traefik for
# TLS-terminated external access. Set to 0.0.0.0 only for trusted LAN exposure.
VLLM_API_BIND=127.0.0.1

# Model Configuration
VLLM_MODEL=google/gemma-4-9b-4bit
VLLM_DTYPE=auto
VLLM_QUANTIZATION=none
VRAM_FRACTION=0.9

# GPU Configuration
CUDA_VISIBLE_DEVICES=0

# Cache Configuration
# Model cache is stored in the named Docker volume 'gemma4_hf_cache', which
# persists across container recreations. To back the cache with a specific host
# path instead, add a docker-compose.override.yml redefining the volume, e.g.:
#   volumes:
#     gemma4_hf_cache:
#       driver: local
#       driver_opts:
#         type: none
#         o: bind
#         device: /absolute/path/on/host

# Traefik Configuration
TRAEFIK_HOST=gemma4.local
TRAEFIK_ENTRYPOINT=websecure
# TLS is enabled on the router (tls=true). Certificate source is configured at
# the Traefik level:
#   - Automatic (ACME/Let's Encrypt, Tailscale): configure a certificatesResolver
#     in Traefik and add a label override, e.g. via a compose override file:
#       traefik.http.routers.gemma4.tls.certresolver: letsencrypt
#   - Manual certificates: configure them via Traefik's file provider using
#     the tls.certificates list — no per-router label is required.

# Container Configuration
CONTAINER_NAME=gemma4-api
LOG_LEVEL=info
